---
// Giscus comments (GitHub Discussions-backed). Free, no DB to run.
//
// SETUP (one-time):
//  1. Push this blog to a PUBLIC GitHub repo and enable its Discussions tab.
//  2. Install the Giscus GitHub app on that repo: https://github.com/apps/giscus
//  3. Go to https://giscus.app, enter the repo, pick a Discussions category
//     (e.g. "Announcements"), and copy the data-repo / data-repo-id /
//     data-category / data-category-id values it generates into the four
//     constants below.
const GISCUS_REPO = 'MoreLogos/famealie-blog';
const GISCUS_REPO_ID = 'R_kgDOS2hXaA';
const GISCUS_CATEGORY = 'Announcements';
const GISCUS_CATEGORY_ID = 'DIC_kwDOS2hXaM4C-5O2';

const configured = !GISCUS_REPO_ID.startsWith('REPLACE');
---

{
  configured && (
    <section class="comments">
      <h2>Discussion</h2>
      <script
        is:inline
        src="https://giscus.app/client.js"
        data-repo={GISCUS_REPO}
        data-repo-id={GISCUS_REPO_ID}
        data-category={GISCUS_CATEGORY}
        data-category-id={GISCUS_CATEGORY_ID}
        data-mapping="pathname"
        data-strict="0"
        data-reactions-enabled="1"
        data-emit-metadata="0"
        data-input-position="bottom"
        data-theme="light"
        data-lang="en"
        crossorigin="anonymous"
        async
      />
    </section>
  )
}

<style>
  .comments {
    width: 720px;
    max-width: calc(100% - 2em);
    margin: 2em auto 0;
    padding: 1em;
  }
</style>
